{
  "expo": {
    "name": "expo-gaode-map-navigation-example",
    "slug": "expo-gaode-map-navigation-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "expogaodemapnavigationexample",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wangqiang.expogaodemapnavigationexample"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.wangqiang.expogaodemapnavigationexample"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-gaode-map-navigation",
        {
          "iosKey": "9351998da2590b73e8ec9b9cec1240c7",
          "androidKey": "778e16e599e6f597b34a42a1ade6293c",
          "enableLocation": true,
          "locationDescription": "需要访问您的位置信息以提供地图服务"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
