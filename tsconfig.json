{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "expo-gaode-map-navigation": [
        "../expo-gaode-map/packages/navigation/src/index.ts"
      ],
      "expo-gaode-map-navigation/*": [
        "../expo-gaode-map/packages/navigation/src/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
